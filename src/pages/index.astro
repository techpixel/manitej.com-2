---
import Layout from '../layouts/Layout.astro';
import Warp from '../components/Warp.svelte';
import foreground from '../assets/foreground.svg?raw';
import foregroundMobile from '../assets/foreground-mobile.svg?raw';
import background from '../assets/background.svg?raw';


// Projects — links live in the PROJECTS column, and any project with both a
// `logo` and `bg` also gets a hover panel that takes over the MOTD slot.
type Project = {
	id: string;
	title: string;
	href?: string;
	note?: string;
	logo?: string;
	bg?: string;
	description?: string;
	tags?: string[];
};

const projects: Project[] = [
	{
		id: 'arcade',
		title: 'Arcade',
		href: 'https://hackclub.com/arcade',
		logo: '/projects/arcade.svg',
		bg: '/projects/arcade_bg.png',
		description: 'Hack Club’s first general YSWS program, ran in partnership with GitHub. Reached 10000+ teens globally and awarded $400,000 in grants and prizes.',
		tags: ['Engineering', 'Program Design'],
	},
	{
		id: 'horizons',
		title: 'Horizons',
		href: 'https://horizons.hackclub.com',
		logo: '/projects/horizons.svg',
		bg: '/projects/horizons_bg.png',
		description: 'A collection of 6 high-quality flagship-level high school hackathons across 6 countries. ',
		tags: ['UI/UX Design', 'Branding', 'Program Design'],
	},
	{
		id: 'campfire',
		title: 'Campfire',
		href: 'https://campfire.hackclub.com',
		logo: '/projects/campfire.svg',
		bg: '/projects/campfire_bg.png',
		description: 'An in-person game jam that took place in 200+ cities across the globe ran in partnership with Open Sauce.\n18,000+ teenagers participated.',
		tags: ['Design', 'Infrastructure'],
	},
	{
		id: 'orchard',
		title: 'Orchard',
		note: '(closed beta)',
		logo: '/projects/orchard.svg',
		bg: '/projects/orchard_bg.png',
		description: 'Orchard is an in-development batteries-included Kubernetes PaaS serving as an alternative to\nDocker-based Coolify.',
		tags: ['Branding'],
	},
	{
		id: 'midnight',
		title: 'Midnight',
		href: 'https://midnight.hackclub.com',
		logo: '/projects/midnight.svg',
		bg: '/projects/midnight_bg.png',
		description: 'Hack Club\'s 4-day murder mystery-themed flagship hackathon in Vienna, Austria!',
		tags: ['UI/UX Design', 'Branding'],
	},
];

const projectPanels = projects.filter(
	(p): p is Required<Project> => Boolean(p.logo && p.bg && p.description)
);
---

<Layout>
	<main class="stage" id="stage">
		<div class="bg-track">
			<div class="bg-zoom">
				<Warp
					client:only="svelte"
					svg={background}
					mode="tide"
					fit="natural"
					class="bg-grid"
					interpolation={180}
					amplitude={22}
					speed={0.15}
					tilesX={3}
					tilesY={3}
				/>
			</div>
		</div>

		<Warp
			client:only="svelte"
			svg={foreground}
			mode="wave"
			fit="natural"
			class="foreground foreground-desktop"
			complexity={8}
			interpolation={40}
			buffer={30}
			amplitude={28}
			speed={1.4}
			period={520}
		/>

		<Warp
			client:only="svelte"
			svg={foregroundMobile}
			mode="wave"
			fit="natural"
			class="foreground foreground-mobile"
			complexity={8}
			interpolation={40}
			buffer={30}
			amplitude={28}
			speed={1.4}
			period={520}
		/>

		<div class="content">
			<section class="content-col about">
				<div class="panels">
					<div class="panel default">
						<p class="bio">I&rsquo;m a passionate designer and a computer science student working at Hack Club.</p>
					</div>
					{projectPanels.map(p => (
						<div class="panel project" data-project={p.id}>
							<div class="logo-card" style={`background-image: url('${p.bg}')`}>
								<img src={p.logo} alt={p.title} class="logo" />
							</div>
							<h4>{p.title.toUpperCase()}</h4>
							<p class="caption">{p.description}</p>
							{p.tags && (
								<div class="tags">
									{p.tags.map(t => <span class="tag">{t}</span>)}
								</div>
							)}
						</div>
					))}
				</div>
			</section>

			<section class="content-col" style="--col-color: #FF6A73;">
				<h3>PROJECTS</h3>
				<ul>
					{projects.map(p => (
						<li>
							{p.href
								? <a href={p.href} data-project={p.id} target="_blank" rel="noopener">{p.title}{p.note && <span class="link-note">{p.note}</span>}</a>
								: <span class="no-link" data-project={p.id}>{p.title}{p.note && <span class="link-note">{p.note}</span>}</span>
							}
						</li>
					))}
				</ul>
			</section>

			<section class="content-col" style="--col-color: #02B9BE;">
				<h3>CONTACT</h3>
				<ul>
					<li>email me at <a href="#" class="email-link" data-user="me" data-domain="manitej.com" aria-label="Copy email address"></a></li>
				</ul>
			</section>

			{/* Temporarily hidden — restore by uncommenting.
			<section class="content-col" style="--col-color: #FFB1A3;">
				<h3>BLOG</h3>
				<ul>
					<li>coming soon</li>
				</ul>
			</section>
			*/}
		</div>
	</main>
</Layout>

<script>
	// Toast text shown when the email is copied. Each successive click pulls
	// the next entry; cycles when the end is reached. Edit / add freely.
	const copiedMessages: string[] = [
		'copied!',
		'copied!',
		'copied!',
		'okay',
	];

	// Email link — visible text and the real address are both built at runtime
	// from data-* parts so neither the obfuscated nor the literal address
	// appears in the static HTML. Click copies the address; a small italic
	// toast appears underneath briefly.
	for (const link of document.querySelectorAll<HTMLAnchorElement>('.email-link')) {
		const user = link.dataset.user ?? '';
		const domain = link.dataset.domain ?? '';
		const display = `(${user} at ${domain.replace(/\./g, ' dot ')})`;
		const real = `${user}@${domain}`;
		link.textContent = display;

		let note: HTMLDivElement | null = null;
		let timer: number | null = null;
		let clicks = 0;
		link.addEventListener('click', async e => {
			e.preventDefault();
			try {
				await navigator.clipboard.writeText(real);
				if (!note) {
					note = document.createElement('div');
					note.className = 'copied-note';
					link.parentElement?.appendChild(note);
				}
				note.textContent = copiedMessages[clicks % copiedMessages.length];
				clicks++;
				note.classList.add('show');
				if (timer) clearTimeout(timer);
				timer = window.setTimeout(() => note?.classList.remove('show'), 1400);
			} catch {
				// clipboard blocked — fall back to mailto
				window.location.href = `mailto:${real}`;
			}
		});
	}

	const stage = document.getElementById('stage')!;
	const reveal = () => stage.classList.add('revealed');
	// The intro timeline (headline slide-up, column stagger) is keyed off
	// .revealed, but the headline only becomes visible once the Warp
	// component mounts and adds .warp-ready. Start the clock at that point —
	// otherwise slow hydration means the headline fades in mid-slide (or
	// already at the top) instead of starting centered. The time cap keeps
	// the content reachable if Warp never mounts.
	const revealWhenReady = () => {
		if (stage.querySelector('.foreground.warp-ready') || performance.now() > 4000) {
			requestAnimationFrame(reveal);
		} else {
			requestAnimationFrame(revealWhenReady);
		}
	};
	requestAnimationFrame(revealWhenReady);
	stage.addEventListener('click', reveal);

	// Background tile scale shrinks as the cursor approaches the bottom-right
	// corner. Uses (x * y) so both axes have to be near 1 for the effect to
	// reach max — top-left = scale 1, bottom-right = scale 0.85. JS lerps
	// the value each frame so the motion stays smooth even when mousemove
	// fires rapidly.
	const bgTrack = stage.querySelector<HTMLElement>('.bg-track');
	if (bgTrack) {
		const maxShrink = 0.4;
		let targetScale = 1;
		let currentScale = 1;
		document.addEventListener('mousemove', e => {
			const x = Math.max(0, Math.min(1, e.clientX / window.innerWidth));
			const y = Math.max(0, Math.min(1, e.clientY / window.innerHeight));
			targetScale = 1 - x * y * maxShrink;
		}, { passive: true });
		const tickScale = () => {
			currentScale += (targetScale - currentScale) * 0.06;
			bgTrack.style.setProperty('--bg-scale', currentScale.toFixed(4));
			requestAnimationFrame(tickScale);
		};
		requestAnimationFrame(tickScale);
	}

	// Per-column parallax drift — each column tracks the cursor's position
	// relative to itself. Target values are lerped toward each frame in JS so
	// both entering and leaving the column are smooth (no CSS-transition
	// restart jitter, no abrupt snap on enter, gentle decay on leave).
	type DriftState = { tx: number; ty: number; cx: number; cy: number };
	const driftStates: { col: HTMLElement; state: DriftState }[] = [];
	const driftRange = 8; // px; max drift at the corners
	for (const col of stage.querySelectorAll<HTMLElement>('.content-col')) {
		const state: DriftState = { tx: 0, ty: 0, cx: 0, cy: 0 };
		driftStates.push({ col, state });
		col.addEventListener('mousemove', e => {
			const r = col.getBoundingClientRect();
			state.tx = ((e.clientX - r.left) / r.width - 0.5) * 2 * driftRange;
			state.ty = ((e.clientY - r.top) / r.height - 0.5) * 2 * driftRange;
		}, { passive: true });
		col.addEventListener('mouseleave', () => {
			state.tx = 0;
			state.ty = 0;
		});
	}
	const tickDrift = () => {
		for (const { col, state } of driftStates) {
			state.cx += (state.tx - state.cx) * 0.18;
			state.cy += (state.ty - state.cy) * 0.18;
			col.style.setProperty('--drift-x', `${state.cx.toFixed(3)}px`);
			col.style.setProperty('--drift-y', `${state.cy.toFixed(3)}px`);
		}
		requestAnimationFrame(tickDrift);
	};
	requestAnimationFrame(tickDrift);
</script>

<style>
	.stage {
		position: relative;
		width: 100vw;
		height: 100vh;
		overflow: hidden;
		background: #0B0B0F;
	}

	.bg-track {
		position: absolute;
		inset: 0;
		overflow: hidden;
		pointer-events: none;
	}

	/* The .bg-zoom wrapper is what actually scales — the .bg-track stays
	   at viewport size with overflow:hidden so scaling the inner SVG just
	   reveals more tiles instead of clipping the viewport. The scale value
	   is lerped each frame in JS, so no CSS transition is needed. */
	.bg-zoom {
		position: absolute;
		inset: 0;
		transform: scale(var(--bg-scale, 1));
		transform-origin: center center;
	}

	/* One SVG containing a 3×3 grid of watermark tiles. Each tile is
	   cover-sized so a single watermark fills the viewport; the whole grid
	   slides diagonally by exactly one tile per cycle and the next identical
	   tile rolls in from the bottom-right (loop is invisible). */
	.bg-track :global(.bg-grid) {
		position: absolute;
		left: 50%;
		top: 50%;
		/* total grid = 3 × cover-style tile, preserving 1541:613 */
		width: calc(3 * max(115vw, calc(115vh * 1541 / 613)));
		aspect-ratio: 1541 / 613;
		opacity: 0;
		animation: slide-grid 200s linear infinite;
		transition: opacity 700ms ease 50ms;
		will-change: transform;
	}

	/* Warp.svelte adds .warp-ready once its SVG is mounted + first frame is
	   transformed, so the fade-in only starts once there's something to see. */
	.bg-track :global(.bg-grid.warp-ready) {
		opacity: 1;
	}

	@keyframes slide-grid {
		from { transform: translate(-50%, -50%); }
		to   { transform: translate(calc(-50% - 100% / 3), calc(-50% - 100% / 3)); }
	}

	:global(.foreground) {
		position: absolute;
		left: 50%;
		/* Starts dead-center; the reveal slides it up to its resting spot
		   above the content row (see .stage.revealed rule below). */
		top: 50%;
		transform: translate(-50%, -50%);
		width: min(88vw, 1350px);
		aspect-ratio: 3410 / 203;
		pointer-events: none;
		opacity: 0;
		/* Three independent transitions: slow opacity for the page-load
		   fade-in, the delayed transform for the intro slide-up (transform,
		   not top, so the move never triggers layout), and fast
		   filter:opacity for the hover-dim so it feels snappy. */
		transition: opacity 700ms ease 50ms, transform 800ms cubic-bezier(0.65, 0, 0.35, 1) 900ms, filter 500ms ease;
	}

	/* Intro: after the headline fades in centered, it slides up to make room
	   for the content (mobile keeps its own static position). */
	.stage.revealed :global(.foreground-desktop) {
		transform: translate(-50%, calc(-50% - 155px));
	}

	/* Mobile foreground SVG is sourced from the background.svg (3-line wrapped
	   layout), so its aspect ratio is different. Hidden on desktop. */
	:global(.foreground-mobile) {
		aspect-ratio: 1541 / 613;
		display: none;
	}

	:global(.foreground.warp-ready) {
		opacity: 1;
	}

	/* Dim the foreground only while hovering an actual link — moving the
	   cursor around columns/panels otherwise leaves the headline at full
	   strength. */
	.stage.revealed:has(.content a:hover) :global(.foreground) {
		filter: opacity(0.2);
	}

	.content {
		position: absolute;
		/* Centered under the headline (headline sits at ~50% - 175px; the
		   content row starts just below the vertical midpoint). */
		left: 50%;
		top: calc(50% - 80px);
		transform: translateX(-50%);
		/* The row is a fixed-width block (424 + 27 + 410 + 410 = 1271px);
		   once the viewport (minus 32px margins each side) can't fit it,
		   shrink the whole block proportionally so nothing overflows. The
		   plain translate above stays as a fallback for browsers that can't
		   divide lengths in calc(). */
		transform: translateX(-50%) scale(min(1, calc((100vw - 64px) / 1271px)));
		transform-origin: top center;
		display: flex;
		/* Columns are fixed-width blocks, so the container just wraps them
		   instead of stretching across the viewport. */
		width: max-content;
		pointer-events: none;
	}

	.stage.revealed .content {
		pointer-events: auto;
	}

	.content-col {
		position: relative;
		/* Fixed block width; border-box so the 27/16px hover-area paddings
		   are included in it (divider + 27px gap + 367px text column). */
		flex: 0 0 410px;
		box-sizing: border-box;
		min-width: 0;
		min-height: 300px;
		color: #FFEECC;
		font-family: 'Darker Grotesque', sans-serif;
		font-weight: 400;
		font-size: 20px;
		line-height: 1;
		padding-left: 27px;
		/* Absorbs the previous gap on the right so the column's hover/parallax
		   area extends to the next column's divider — tracking only ever
		   happens to the right of this column's own divider. */
		padding-right: 16px;
		/* Children that translate from -100% are clipped at the column edge,
		   so the slide reads as text emerging from behind the divider. */
		overflow: hidden;
		transition: color 200ms ease;
	}

	.content-col:hover {
		color: var(--col-color, #FFEECC);
	}

	/* Per-column stagger so each column does its own (line → header → links)
	   sequence, with the next column starting partway through the previous.
	   The initial 1500ms gap lets the headline fade in centered (~700ms) and
	   slide up (900ms + 800ms) before the content starts drawing. */
	.content-col { --col-delay: 1500ms; }
	.content-col:nth-child(3) { --col-delay: 2300ms; }
	.content-col:nth-child(4) { --col-delay: 3100ms; }

	/* Vertical divider draws down at the column's left edge */
	.content-col::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0;
		width: 4px;
		height: 100%;
		background: #FFEECC;
		transform-origin: top;
		transform: scaleY(0);
		transition: transform 1000ms ease var(--col-delay), background 200ms ease;
		/* Above the sliding text so it visually emerges from underneath. */
		z-index: 2;
	}

	.stage.revealed .content-col::before {
		transform: scaleY(1);
	}

	/* Header flies out from behind the line. */
	.content-col:not(.about) > h3 {
		transform: translateX(-110%);
		transition: transform 1000ms ease;
		transition-delay: calc(var(--col-delay) + 800ms);
	}

	.stage.revealed .content-col:not(.about) > h3 {
		transform: translateX(0);
	}

	/* Each link in the list flies out one-by-one after the header. */
	.content-col:not(.about) > ul > li {
		--link-i: 0;
		transform: translateX(-110%);
		transition: transform 800ms ease;
		transition-delay: calc(var(--col-delay) + 1500ms + var(--link-i) * 200ms);
	}

	.content-col:not(.about) > ul > li:nth-child(2) { --link-i: 1; }
	.content-col:not(.about) > ul > li:nth-child(3) { --link-i: 2; }
	.content-col:not(.about) > ul > li:nth-child(4) { --link-i: 3; }
	.content-col:not(.about) > ul > li:nth-child(5) { --link-i: 4; }
	.content-col:not(.about) > ul > li:nth-child(6) { --link-i: 5; }

	.stage.revealed .content-col:not(.about) > ul > li {
		transform: translateX(0);
	}

	/* MOTD column fades in when the PROJECTS links start flying in
	   (--col-delay 1500ms + 1500ms link offset = 3000ms after reveal). */
	.content-col.about > * {
		opacity: 0;
		transition: opacity 900ms ease 3000ms;
	}

	.stage.revealed .content-col.about > * {
		opacity: 1;
	}

	/* MOTD column has no rule on its left and is right-aligned */
	.content-col.about {
		flex: 0 0 424px;
		padding-left: 0;
		padding-right: 0;
		text-align: right;
		/* No divider here, so the parallax-drifted panels can spill over the
		   right edge instead of getting clipped. */
		overflow: visible;
	}

	/* Visual gap between MOTD and the first link column. It's a margin (not
	   a flex gap or padding) so neither column claims hover/parallax in it. */
	.content-col.about + .content-col {
		margin-left: 27px;
	}

	.content-col.about::before {
		display: none;
	}

	/* About panel — replaces the old MOTD */
	.content-col.about .panel.default {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.content-col.about .panel.default p {
		margin: 0;
	}

	.content-col.about .panel.default .bio {
		font-size: 36px;
		font-weight: 500;
	}

	/* Stacked panels swap on link hover */
	.content-col.about .panels {
		position: relative;
		width: 100%;
		min-height: 300px;
	}

	.content-col.about .panel {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 200ms ease;
		pointer-events: none;
	}

	.content-col.about .panel.default {
		opacity: 1;
	}

	/* Hovering a project link in the menu hides the default MOTD and shows
	   that project's panel. Wrapped in @media (hover: hover) so it doesn't
	   trigger on touch devices — there, the first tap should follow the link
	   directly instead of priming a hover panel that needs a second tap. */
	@media (hover: hover) {
		/* Any menu entry (linked or not) hides the default panel… */
		.content:has(li [data-project]:hover) .panel.default {
			opacity: 0;
		}

		/* …and shows its own project panel. */
		.content:has(li [data-project="arcade"]:hover) .panel[data-project="arcade"],
		.content:has(li [data-project="midnight"]:hover) .panel[data-project="midnight"],
		.content:has(li [data-project="campfire"]:hover) .panel[data-project="campfire"],
		.content:has(li [data-project="horizons"]:hover) .panel[data-project="horizons"],
		.content:has(li [data-project="orchard"]:hover) .panel[data-project="orchard"] {
			opacity: 1;
		}
	}

	.panel.project {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.panel.project h4 {
		margin: 16px 0 0 0;
		font-family: 'Bowlby One', sans-serif;
		font-weight: 400;
		font-size: 36px;
		line-height: 0.8;
		color: #FFEECC;
	}

	.panel.project .logo-card {
		width: 100%;
		height: 105px;
		padding: 16px;
		box-sizing: border-box;
		background-color: #faefd6;
		background-size: cover;
		background-position: center;
		overflow: hidden;
	}

	.panel.project .logo-card .logo {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: center;
	}

	.panel.project .caption {
		margin: 8px 0 0 0;
		font-size: 20px;
		font-weight: 500;
		line-height: 1;
		color: #FCF2DD;
		/* Honor \n line breaks in project descriptions */
		white-space: pre-line;
		/* Same cap trim the design applies, so the gaps around the caption
		   are measured from the glyphs rather than the font's leading. */
		text-box: trim-both cap alphabetic;
	}

	/* Tag pills under the caption, right-aligned like the rest of the column */
	.panel.project .tags {
		display: flex;
		gap: 8px;
		justify-content: flex-end;
		margin-top: 8px;
	}

	.panel.project .tag {
		background: #FFEECC;
		color: #121118;
		font-size: 16px;
		font-weight: 500;
		line-height: 1;
		/* Trim the font's built-in leading above the caps and below the
		   baseline so the label sits optically centered in the pill and the
		   8px padding is real (Darker Grotesque carries a lot of leading). */
		text-box: trim-both cap alphabetic;
		padding: 8px;
		border-radius: 1000px;
	}

	.content-col h3 {
		margin: 4px 0 8px 0;
		font-family: 'Bowlby One', sans-serif;
		font-weight: 400;
		font-size: 36px;
		line-height: 0.8;
		letter-spacing: 0.01em;
		transition: color 200ms ease;
	}

	/* Link columns use the large display size; the showcase column keeps
	   its smaller body copy. */
	.content-col:not(.about) ul {
		font-size: 36px;
	}

	/* Hovering a column also tints the divider line */
	.content-col:hover::before {
		background: var(--col-color, #FFEECC);
	}

	.content-col ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.content-col a {
		color: inherit;
		text-decoration: none;
		display: inline-block;
		transform-origin: left center;
		/* Variable-font weight animates fluidly via font-variation-settings */
		font-variation-settings: 'wght' 400;
		transition: font-variation-settings 200ms ease, transform 200ms ease, color 200ms ease;
	}

	/* Italic "copied!" toast under the email link */
	.content-col :global(.copied-note) {
