---
import Layout from '../layouts/Layout.astro';
import Warp from '../components/Warp.svelte';
import foreground from '../assets/foreground.svg?raw';
import background from '../assets/background.svg?raw';


// Projects — links live in the PROJECTS column, and any project with both a
// `logo` and `bg` also gets a hover panel that takes over the MOTD slot.
type Project = {
	id: string;
	title: string;
	href: string;
	logo?: string;
	bg?: string;
	description?: string;
};

const projects: Project[] = [
	{
		id: 'arcade',
		title: 'Arcade',
		href: 'https://hackclub.com/arcade',
		logo: '/projects/arcade.svg',
		bg: '/projects/arcade_bg.png',
		description: 'My first major project. Hack Club’s first general YSWS.',
	},
	{
		id: 'midnight',
		title: 'Midnight',
		href: 'https://midnight.hackclub.com',
		logo: '/projects/midnight.svg',
		bg: '/projects/midnight_bg.png',
		description: 'A murder mystery hackathon in Vienna!',
	},
	{
		id: 'campfire',
		title: 'Campfire',
		href: 'https://campfire.hackclub.com',
		logo: '/projects/campfire.svg',
		bg: '/projects/campfire_bg.png',
		description: 'A game jam happening across 200+ cities simulatenously.',
	},
	{
		id: 'horizons',
		title: 'Horizons',
		href: 'https://horizons.hackclub.com',
		logo: '/projects/horizons.svg',
		bg: '/projects/horizons_bg.png',
		description: '7 flagship hackathons across 7 continents. You\'re invited.',
	},
];

const projectPanels = projects.filter(
	(p): p is Required<Project> => Boolean(p.logo && p.bg && p.description)
);
---

<Layout>
	<main class="stage" id="stage">
		<div class="bg-track">
			<div class="bg-zoom">
				<Warp
					client:only="svelte"
					svg={background}
					mode="tide"
					fit="natural"
					class="bg-grid"
					interpolation={180}
					amplitude={22}
					speed={0.15}
					tilesX={3}
					tilesY={3}
				/>
			</div>
		</div>

		<Warp
			client:only="svelte"
			svg={foreground}
			mode="wave"
			fit="natural"
			class="foreground"
			complexity={8}
			interpolation={40}
			buffer={30}
			amplitude={28}
			speed={1.4}
			period={520}
		/>

		<div class="content">
			<section class="content-col about">
				<div class="panels">
					<div class="panel default">
						<p class="lead">hey! i&rsquo;m manitej</p>
						<p class="bio">i&rsquo;m a designer and computer science student currently working at Hack Club.</p>
					</div>
					{projectPanels.map(p => (
						<div class="panel project" data-project={p.id}>
							<h4>{p.title.toUpperCase()}</h4>
							<div class="logo-card" style={`background-image: url('${p.bg}')`}>
								<img src={p.logo} alt={p.title} class="logo" />
							</div>
							<p class="caption">{p.description}</p>
						</div>
					))}
				</div>
			</section>

			<section class="content-col" style="--col-color: #FF6A73;">
				<h3>PROJECTS</h3>
				<ul>
					{projects.map(p => (
						<li><a href={p.href} data-project={p.id} target="_blank" rel="noopener">{p.title}</a></li>
					))}
				</ul>
			</section>

			<section class="content-col" style="--col-color: #02B9BE;">
				<h3>CONTACT</h3>
				<ul>
					<li>email me at <a href="#" class="email-link" data-user="me" data-domain="manitej.com" aria-label="Copy email address"></a></li>
				</ul>
			</section>

			<section class="content-col" style="--col-color: #FFB1A3;">
				<h3>BLOG</h3>
				<ul>
					<li>coming soon</li>
				</ul>
			</section>
		</div>
	</main>
</Layout>

<script>
	// Toast text shown when the email is copied. Each successive click pulls
	// the next entry; cycles when the end is reached. Edit / add freely.
	const copiedMessages: string[] = [
		'copied!',
		'copied!',
		'copied!',
		'okay',
	];

	// Email link — visible text and the real address are both built at runtime
	// from data-* parts so neither the obfuscated nor the literal address
	// appears in the static HTML. Click copies the address; a small italic
	// toast appears underneath briefly.
	for (const link of document.querySelectorAll<HTMLAnchorElement>('.email-link')) {
		const user = link.dataset.user ?? '';
		const domain = link.dataset.domain ?? '';
		const display = `(${user} at ${domain.replace(/\./g, ' dot ')})`;
		const real = `${user}@${domain}`;
		link.textContent = display;

		let note: HTMLDivElement | null = null;
		let timer: number | null = null;
		let clicks = 0;
		link.addEventListener('click', async e => {
			e.preventDefault();
			try {
				await navigator.clipboard.writeText(real);
				if (!note) {
					note = document.createElement('div');
					note.className = 'copied-note';
					link.parentElement?.appendChild(note);
				}
				note.textContent = copiedMessages[clicks % copiedMessages.length];
				clicks++;
				note.classList.add('show');
				if (timer) clearTimeout(timer);
				timer = window.setTimeout(() => note?.classList.remove('show'), 1400);
			} catch {
				// clipboard blocked — fall back to mailto
				window.location.href = `mailto:${real}`;
			}
		});
	}

	const stage = document.getElementById('stage')!;
	const reveal = () => stage.classList.add('revealed');
	// Defer one frame so the initial state paints and transitions fire
	requestAnimationFrame(() => requestAnimationFrame(reveal));
	stage.addEventListener('click', reveal);

	// Background tile scale shrinks as the cursor approaches the bottom-right
	// corner. Uses (x * y) so both axes have to be near 1 for the effect to
	// reach max — top-left = scale 1, bottom-right = scale 0.85. JS lerps
	// the value each frame so the motion stays smooth even when mousemove
	// fires rapidly.
	const bgTrack = stage.querySelector<HTMLElement>('.bg-track');
	if (bgTrack) {
		const maxShrink = 0.4;
		let targetScale = 1;
		let currentScale = 1;
		document.addEventListener('mousemove', e => {
			const x = Math.max(0, Math.min(1, e.clientX / window.innerWidth));
			const y = Math.max(0, Math.min(1, e.clientY / window.innerHeight));
			targetScale = 1 - x * y * maxShrink;
		}, { passive: true });
		const tickScale = () => {
			currentScale += (targetScale - currentScale) * 0.06;
			bgTrack.style.setProperty('--bg-scale', currentScale.toFixed(4));
			requestAnimationFrame(tickScale);
		};
		requestAnimationFrame(tickScale);
	}

	// Per-column parallax drift — each column tracks the cursor's position
	// relative to itself. Target values are lerped toward each frame in JS so
	// both entering and leaving the column are smooth (no CSS-transition
	// restart jitter, no abrupt snap on enter, gentle decay on leave).
	type DriftState = { tx: number; ty: number; cx: number; cy: number };
	const driftStates: { col: HTMLElement; state: DriftState }[] = [];
	const driftRange = 8; // px; max drift at the corners
	for (const col of stage.querySelectorAll<HTMLElement>('.content-col')) {
		const state: DriftState = { tx: 0, ty: 0, cx: 0, cy: 0 };
		driftStates.push({ col, state });
		col.addEventListener('mousemove', e => {
			const r = col.getBoundingClientRect();
			state.tx = ((e.clientX - r.left) / r.width - 0.5) * 2 * driftRange;
			state.ty = ((e.clientY - r.top) / r.height - 0.5) * 2 * driftRange;
		}, { passive: true });
		col.addEventListener('mouseleave', () => {
			state.tx = 0;
			state.ty = 0;
		});
	}
	const tickDrift = () => {
		for (const { col, state } of driftStates) {
			state.cx += (state.tx - state.cx) * 0.18;
			state.cy += (state.ty - state.cy) * 0.18;
			col.style.setProperty('--drift-x', `${state.cx.toFixed(3)}px`);
			col.style.setProperty('--drift-y', `${state.cy.toFixed(3)}px`);
		}
		requestAnimationFrame(tickDrift);
	};
	requestAnimationFrame(tickDrift);
</script>

<style>
	.stage {
		position: relative;
		width: 100vw;
		height: 100vh;
		overflow: hidden;
		background: #000000;
	}

	.bg-track {
		position: absolute;
		inset: 0;
		overflow: hidden;
		pointer-events: none;
	}

	/* The .bg-zoom wrapper is what actually scales — the .bg-track stays
	   at viewport size with overflow:hidden so scaling the inner SVG just
	   reveals more tiles instead of clipping the viewport. The scale value
	   is lerped each frame in JS, so no CSS transition is needed. */
	.bg-zoom {
		position: absolute;
		inset: 0;
		transform: scale(var(--bg-scale, 1));
		transform-origin: center center;
	}

	/* One SVG containing a 3×3 grid of watermark tiles. Each tile is
	   cover-sized so a single watermark fills the viewport; the whole grid
	   slides diagonally by exactly one tile per cycle and the next identical
	   tile rolls in from the bottom-right (loop is invisible). */
	.bg-track :global(.bg-grid) {
		position: absolute;
		left: 50%;
		top: 50%;
		/* total grid = 3 × cover-style tile, preserving 1541:613 */
		width: calc(3 * max(115vw, calc(115vh * 1541 / 613)));
		aspect-ratio: 1541 / 613;
		opacity: 0;
		animation: slide-grid 200s linear infinite;
		transition: opacity 700ms ease 50ms;
		will-change: transform;
	}

	.stage.revealed .bg-track :global(.bg-grid) {
		opacity: 1;
	}

	@keyframes slide-grid {
		from { transform: translate(-50%, -50%); }
		to   { transform: translate(calc(-50% - 100% / 3), calc(-50% - 100% / 3)); }
	}

	:global(.foreground) {
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		width: min(92vw, 1500px);
		aspect-ratio: 4362 / 203;
		pointer-events: none;
		opacity: 0;
		/* Two independent transitions: slow opacity for the page-load fade-in,
		   fast filter:opacity for the hover-dim so it feels snappy. */
		transition: opacity 700ms ease 50ms, filter 500ms ease;
	}

	.stage.revealed :global(.foreground) {
		opacity: 1;
	}

	/* Dim the foreground when the user is interacting with the content. */
	.stage.revealed:has(.content:hover) :global(.foreground) {
		filter: opacity(0.2);
	}

	.content {
		position: absolute;
		left: 32px;
		top: 0;
		display: flex;
		/* Width tuning:
		   - At vw=1440 all three formulas equal 1040px (the look you tuned).
		   - Above 1440: `100vw - 400px` wins (linear, preserves desktop look).
		   - Below 1440: `30vw + 608px` wins — columns shrink at only 30%
		     the rate of the viewport, so each section noticeably expands
		     in relative width as the viewport narrows.
		   - Outer min() caps everything at `100vw - 32px` so very small
		     viewports never push content outside the screen. */
		width: min(
			max(calc(100vw - 400px), calc(30vw + 608px)),
			calc(100vw - 32px)
		);
		pointer-events: none;
	}

	.stage.revealed .content {
		pointer-events: auto;
	}

	.content-col {
		position: relative;
		flex: 1 1 0;
		min-width: 0;
		min-height: 236px;
		color: #fff;
		font-family: 'Darker Grotesque', sans-serif;
		font-weight: 400;
		font-size: 20px;
		line-height: 1;
		padding-left: 16px;
		/* Absorbs the previous gap on the right so the column's hover/parallax
		   area extends to the next column's divider — tracking only ever
		   happens to the right of this column's own divider. */
		padding-right: 32px;
		/* Children that translate from -100% are clipped at the column edge,
		   so the slide reads as text emerging from behind the divider. */
		overflow: hidden;
		transition: color 200ms ease;
	}

	.content-col:hover {
		color: var(--col-color, #fff);
	}

	/* Per-column stagger so each column does its own (line → header → links)
	   sequence, with the next column starting partway through the previous.
	   Initial 600ms gap before anything animates so the page settles first. */
	.content-col { --col-delay: 600ms; }
	.content-col:nth-child(3) { --col-delay: 1400ms; }
	.content-col:nth-child(4) { --col-delay: 2200ms; }

	/* Vertical divider draws down at the column's left edge */
	.content-col::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0;
		width: 2px;
		height: 100%;
		background: #fff;
		transform-origin: top;
		transform: scaleY(0);
		transition: transform 1000ms ease var(--col-delay), background 200ms ease;
		/* Above the sliding text so it visually emerges from underneath. */
		z-index: 2;
	}

	.stage.revealed .content-col::before {
		transform: scaleY(1);
	}

	/* Header flies out from behind the line. */
	.content-col:not(.about) > h3 {
		transform: translateX(-110%);
		transition: transform 1000ms ease;
		transition-delay: calc(var(--col-delay) + 800ms);
	}

	.stage.revealed .content-col:not(.about) > h3 {
		transform: translateX(0);
	}

	/* Each link in the list flies out one-by-one after the header. */
	.content-col:not(.about) > ul > li {
		--link-i: 0;
		transform: translateX(-110%);
		transition: transform 800ms ease;
		transition-delay: calc(var(--col-delay) + 1500ms + var(--link-i) * 200ms);
	}

	.content-col:not(.about) > ul > li:nth-child(2) { --link-i: 1; }
	.content-col:not(.about) > ul > li:nth-child(3) { --link-i: 2; }
	.content-col:not(.about) > ul > li:nth-child(4) { --link-i: 3; }
	.content-col:not(.about) > ul > li:nth-child(5) { --link-i: 4; }
	.content-col:not(.about) > ul > li:nth-child(6) { --link-i: 5; }

	.stage.revealed .content-col:not(.about) > ul > li {
		transform: translateX(0);
	}

	/* MOTD column fades in when the PROJECTS links start flying in
	   (--col-delay 600ms + 1500ms link offset = 2100ms after reveal). */
	.content-col.about > * {
		opacity: 0;
		transition: opacity 900ms ease 2100ms;
	}

	.stage.revealed .content-col.about > * {
		opacity: 1;
	}

	/* MOTD column has no rule on its left and is right-aligned */
	.content-col.about {
		flex: 0 0 260px;
		padding-left: 0;
		padding-right: 0;
		text-align: right;
		/* No divider here, so the parallax-drifted panels can spill over the
		   right edge instead of getting clipped. */
		overflow: visible;
	}

	/* Visual gap between MOTD and the first link column. It's a margin (not
	   a flex gap or padding) so neither column claims hover/parallax in it. */
	.content-col.about + .content-col {
		margin-left: 32px;
	}

	.content-col.about::before {
		display: none;
	}

	/* About panel — replaces the old MOTD */
	.content-col.about .panel.default {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.content-col.about .panel.default p {
		margin: 0;
	}

	.content-col.about .panel.default .lead {
		margin-top: 16px;
		font-size: 24px;
	}

	.content-col.about .panel.default .bio {
		font-size: 20px;
	}

	/* Stacked panels swap on link hover */
	.content-col.about .panels {
		position: relative;
		width: 100%;
		min-height: 200px;
	}

	.content-col.about .panel {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 200ms ease;
		pointer-events: none;
	}

	.content-col.about .panel.default {
		opacity: 1;
	}

	/* Hovering a project link in the menu hides the default MOTD and shows
	   that project's panel. One :has() rule per project that has a panel. */
	.content:has(a[data-project="arcade"]:hover) .panel.default,
	.content:has(a[data-project="midnight"]:hover) .panel.default,
	.content:has(a[data-project="campfire"]:hover) .panel.default,
	.content:has(a[data-project="horizons"]:hover) .panel.default {
		opacity: 0;
	}

	.content:has(a[data-project="arcade"]:hover) .panel[data-project="arcade"],
	.content:has(a[data-project="midnight"]:hover) .panel[data-project="midnight"],
	.content:has(a[data-project="campfire"]:hover) .panel[data-project="campfire"],
	.content:has(a[data-project="horizons"]:hover) .panel[data-project="horizons"] {
		opacity: 1;
	}

	.panel.project {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.panel.project h4 {
		margin: 1px 0 0 0;
		font-family: 'Bowlby One', sans-serif;
		font-weight: 400;
		font-size: 24px;
		line-height: 0.8;
		color: #fff;
	}

	.panel.project .logo-card {
		width: 100%;
		height: 96px;
		padding: 16px;
		box-sizing: border-box;
		background-color: #faefd6;
		background-size: cover;
		background-position: center;
		overflow: hidden;
	}

	.panel.project .logo-card .logo {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: center;
	}

	.panel.project .caption {
		margin: 0;
		font-size: 20px;
		line-height: 1;
	}

	.content-col h3 {
		margin: 1px 0 12px 0;
		font-family: 'Bowlby One', sans-serif;
		font-weight: 400;
		font-size: 24px;
		line-height: 0.8;
		letter-spacing: 0.01em;
		transition: color 200ms ease;
	}

	/* Hovering a column also tints the divider line */
	.content-col:hover::before {
		background: var(--col-color, #fff);
	}

	.content-col ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.content-col a {
		color: inherit;
		text-decoration: none;
		display: inline-block;
		transform-origin: left center;
		/* Variable-font weight animates fluidly via font-variation-settings */
		font-variation-settings: 'wght' 400;
		transition: font-variation-settings 200ms ease, transform 200ms ease, color 200ms ease;
	}

	/* Tiny italic "copied!" toast under the email link */
	.content-col :global(.copied-note) {
		font-style: italic;
		font-size: 14px;
		margin-top: 4px;
		opacity: 0;
		transition: opacity 200ms ease;
	}

	.content-col :global(.copied-note.show) {
		opacity: 1;
	}

	.content-col a:hover {
		font-variation-settings: 'wght' 700;
		transform: scale(1.12);
	}

	/* Each link list (and the about panels) drift subtly with the cursor;
	   the variable is lerped each frame in JS, so no CSS transform transition
	   is needed. The opacity transition still drives the about panels' fade-in. */
	.content-col ul,
	.content-col.about .panels {
		transform: translate(var(--drift-x, 0), var(--drift-y, 0));
		transition: opacity 900ms ease 2100ms;
	}

	/* ───── Collapsed layout: narrow viewports stack vertically ──────────
	   - .content turns into a single 184px-wide column at left:16px
	   - dividers are static horizontal lines above each section
	   - text is left-aligned (about loses its right-align)
	   - all reveal/slide animations are off; overflow is allowed so long
	     content (e.g. the email link) extends past the column boundary
	     instead of being clipped */
	@media (max-width: 768px) {
		.content {
			flex-direction: column;
			gap: 32px;
			width: 184px;
			left: 16px;
		}

		.content-col {
			flex: 0 0 auto;
			width: 100%;
			padding: 16px 0 0 0;
			min-height: auto;
			text-align: left;
			overflow: visible;
		}

		.content-col.about {
			flex: 0 0 auto;
			width: 100%;
			padding: 0;
			text-align: left;
			overflow: visible;
		}

		.content-col.about + .content-col {
			margin-left: 0;
		}

		.content-col.about .panel.default p {
			margin: 1px 0 1em 0;
		}

		/* Divider: a static horizontal line above each section. */
		.content-col::before {
			left: 0;
			top: 0;
			width: 100%;
			height: 2px;
			transform-origin: left;
			transform: scaleX(1);
			transition: none;
		}

		/* Disable the slide-in transforms — content sits at its rest pos. */
		.content-col:not(.about) > h3,
		.content-col:not(.about) > ul > li {
			transform: none;
			transition: none;
		}

		/* Cursor drift on the link list also disabled. */
		.content-col ul {
			transform: none;
			transition: none;
		}

		/* MOTD panel reveal animation off too. */
		.content-col.about > * {
			opacity: 1;
			transition: none;
		}

		/* Foreground SVG: shrink and re-position to clear the stacked column */
		:global(.foreground) {
			top: 50%;
			left: auto;
			right: 16px;
			transform: translateY(-50%);
			width: min(60vw, 320px);
		}
	}
</style>
